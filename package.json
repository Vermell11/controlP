    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@types/three": "0.185.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.17",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
